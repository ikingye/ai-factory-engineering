flowchart LR
  Candidate["候选模型"] --> Offline["离线能力评测"]
  Candidate --> Domain["领域评测"]
  Candidate --> Safety["安全 / 红队"]
  Candidate --> Perf["性能 / 成本评测"]
  Offline --> Gate["上线门禁"]
  Domain --> Gate
  Safety --> Gate
  Perf --> Gate
  Gate --> Canary["灰度 / A-B"]
