flowchart TB
  Workload["model / batch / context profile"] --> Plan["parallelism plan"]
  Plan --> DataState["data + model state pressure"]
  Plan --> ModelCompute["layer / depth / MoE pressure"]
  Plan --> Context["activation / long context pressure"]
  DataState --> DP["Data Parallel\nreplica + batch shard"]
  DataState --> ZeRO["ZeRO / FSDP\noptimizer / grad / param shard"]
  ModelCompute --> TP["Tensor Parallel\nmatrix / head shard"]
  ModelCompute --> PP["Pipeline Parallel\nstage + micro-batch"]
  ModelCompute --> EP["Expert Parallel\nexpert shard + router"]
  Context --> SP["SP / CP\nsequence or context shard"]
  DP --> Groups["rank groups"]
  ZeRO --> Groups
  TP --> Groups
  PP --> Groups
  EP --> Groups
  SP --> Groups
  Groups --> Comm["communication plan\nAllReduce / RS / AG / A2A / P2P"]
  Comm --> Placement["topology-aware placement"]
  Placement --> Intra["scale-up domain\nNVLink / NVSwitch"]
  Placement --> Inter["scale-out fabric\nIB / RoCE / RDMA"]
  Placement --> Metrics["run evidence\nrank / group / topology metrics"]
