  Handler --> Hook["nvidia runtime / OCI hook\nlegacy injection"]
  Handler --> Native["OCI runtime consumes CDI\nstandard device injection"]
  Hook --> Container["container\n/dev/nvidia* + driver libs"]
  Native --> Container
