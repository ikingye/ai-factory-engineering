flowchart TB
  DP["GPU Device Plugin\n发现 / 分配 GPU"] --> Strategy{"device list strategy"}
  Strategy --> Env["envvar / volume / legacy path\nNVIDIA_VISIBLE_DEVICES"]
  Strategy --> CDI["CDI spec\nvendor.com/device=GPU-uuid"]
