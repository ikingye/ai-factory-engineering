  Control --> Policy["策略 / 成本 / 准入"]
  Control --> Train["训练集群<br/>Slurm / Kubernetes"]
  Control --> Infer["生产推理集群<br/>Kubernetes"]
  Control --> Batch["批量与评测集群"]
  Control --> Exp["实验 / 验收集群"]
  Train --> Registry["model registry / checkpoint"]
